# Required — drives the AI agent.
ANTHROPIC_API_KEY=sk-ant-...

# local (self-host, default) or hosted
KERF_MODE=local

# --- Self-host (local mode) ---
KERF_DATA_DIR=./data          # where SQLite + uploaded files live
KERF_ALLOW_SIGNUPS=false      # open public signups on a local instance
PUBLIC_URL=http://localhost:3000
BLENDER_WORKER_URL=http://localhost:8080

# --- Hosted mode only — the app talks to your platform backend over HTTP ---
# HOSTED_AUTH_URL=https://auth.example.com
# HOSTED_BILLING_URL=https://billing.example.com
# HOSTED_SERVICE_TOKEN=        # service-to-service bearer for billing calls

# --- Optional: print + ship (future) ---
# SLANT3D_API_KEY=
# SLANT3D_API_URL=https://api.slant3d.com/v1
