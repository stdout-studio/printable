# Required — drives the AI agent.
ANTHROPIC_API_KEY=sk-ant-...

# local (self-host, default) or studio (hosted on stdout.studio)
STDOUT_MODE=local

# --- Self-host (local mode) ---
STDOUT_DATA_DIR=./data          # where SQLite + uploaded files live
STDOUT_ALLOW_SIGNUPS=false      # open public signups on a local instance
PUBLIC_URL=http://localhost:3000
BLENDER_WORKER_URL=http://localhost:8080

# --- Studio mode only (hosted) — the app talks to the platform services ---
# STUDIO_AUTH_URL=https://auth.stdout.studio
# STUDIO_BILLING_URL=https://billing.stdout.studio
# STUDIO_SERVICE_TOKEN=          # service-to-service bearer for billing calls

# --- Optional: print + ship (future) ---
# SLANT3D_API_KEY=
# SLANT3D_API_URL=https://api.slant3d.com/v1
